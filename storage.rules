rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Doğrulama fotoğrafları yalnızca sunucu (Admin SDK) yazar/okur/siler.
    // Kadın temsilci fotoğrafı /api/temsilci/.../photo üzerinden görür — client erişimi kapalı.
    match /verifications/{allPaths=**} {
      allow read, write: if false;
    }
  }
}
