# Firebase (Firebase Console > Project Settings > General)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Push bildirimleri — Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
# Gerekli olaylar: doğrulama onayı, yeni mesaj, yorum, acil sinyal
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Admin paneli — istatistik, moderasyon, temsilci ekleme (doğrulama fotoğrafı yok)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=guclu_sifre_buraya

# Temsilci paneli — fotoğraf onay/red (admin değil!)
# İsteğe bağlı yedek: admin panelden Firestore reps de eklenebilir
REP_USERNAME=temsilci
REP_PASSWORD=guclu_temsilci_sifresi

# Service Account — Firebase Console > Service Accounts > Generate new private key
# JSON'un TAMAMINI tek satır olarak yapıştır
FIREBASE_SERVICE_ACCOUNT_JSON=

# Doğrulama fotoğrafı depolama: local (dev/VPS) | firestore (Vercel/Spark) | firebase (Storage/Blaze)
# Vercel'de otomatik firestore seçilir; local'de disk kullanılır.
VERIFICATION_PHOTO_STORAGE=local

# Production imzalı oturum (admin/temsilci) — rastgele uzun bir string (32+ karakter)
SESSION_SECRET=
