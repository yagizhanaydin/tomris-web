# Firebase (Firebase Console > Project Settings > General)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin paneli — genel yönetim (doğrulama değil)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=guclu_sifre_buraya

# Temsilci paneli — fotoğraf onay/red (admin değil!)
REP_USERNAME=temsilci
REP_PASSWORD=guclu_temsilci_sifresi

# Service Account — Firebase Console > Service Accounts > Generate new private key
# JSON'un TAMAMINI tek satır olarak yapıştır
FIREBASE_SERVICE_ACCOUNT_JSON=

# Doğrulama fotoğrafı depolama: local (varsayılan, npm run dev / VPS) | firebase (Vercel)
# Vercel'de otomatik firebase seçilir; local'de disk kullanılır.
VERIFICATION_PHOTO_STORAGE=local

# Production imzalı oturum (admin/temsilci) — rastgele uzun bir string
SESSION_SECRET=
