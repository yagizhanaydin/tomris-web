rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApproved() {
      return isSignedIn() && me().verificationStatus == 'approved';
    }

    function myGender() {
      return me().gender;
    }

    function myUsername() {
      return me().username;
    }

    function canViewAudience(audience) {
      return audience == 'all' || audience == myGender();
    }

    /** Onaylı olmayan kullanıcı yalnızca `all` gönderileri okuyabilir */
    function canReadAudienceContent(audience) {
      return audience == 'all' || (isApproved() && canViewAudience(audience));
    }

    function authorIntegrity(data) {
      return data.authorUid == request.auth.uid &&
        data.authorGender == myGender() &&
        data.authorUsername == myUsername();
    }

    function textLen(text, max) {
      return text is string && text.size() > 0 && text.size() <= max;
    }

    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function blockDocId(blockerUid, blockedUid) {
      return blockerUid + '_' + blockedUid;
    }

    /** İki kullanıcı birbirini engellediyse içerik okuma/yazma kapalı */
    function notBlockedWith(authorUid) {
      return !exists(/databases/$(database)/documents/blocks/$(blockDocId(request.auth.uid, authorUid))) &&
        !exists(/databases/$(database)/documents/blocks/$(blockDocId(authorUid, request.auth.uid)));
    }

    function userSelfUpdateAllowed() {
      let diff = request.resource.data.diff(resource.data);
      let keys = diff.affectedKeys();
      return keys.hasOnly(['chatVisibility']) ||
        (
          keys.hasOnly(['verificationPhotoPath', 'verificationStatus', 'genderVerified']) &&
          resource.data.verificationStatus in ['unverified', 'rejected'] &&
          request.resource.data.verificationStatus == 'pending' &&
          request.resource.data.genderVerified == false &&
          request.resource.data.verificationPhotoPath == request.auth.uid
        );
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        isOwner(userId) ||
        (isApproved() && resource.data.verificationStatus == 'approved')
      );
      allow create: if isOwner(userId) &&
        request.resource.data.verificationStatus == 'unverified' &&
        request.resource.data.genderVerified == false &&
        !('bannedAt' in request.resource.data) &&
        !('banReason' in request.resource.data) &&
        !('reviewedAt' in request.resource.data) &&
        !('email' in request.resource.data) &&
        request.resource.data.gender in ['kadin', 'erkek'] &&
        request.resource.data.username is string &&
        request.resource.data.username.size() >= 3 &&
        request.resource.data.username.size() <= 20;
      allow update: if isOwner(userId) && userSelfUpdateAllowed();
      allow delete: if false;
    }

    match /usernames/{username} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.username == username &&
        username.size() >= 3 &&
        username.size() <= 20 &&
        !exists(/databases/$(database)/documents/usernames/$(username));
      allow update, delete: if false;
    }

    match /friendships/{friendshipId} {
      allow read: if isSignedIn() &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);

      allow create: if isApproved() &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.fromUsername == myUsername() &&
        request.resource.data.fromUid != request.resource.data.toUid &&
        userExists(request.resource.data.toUid) &&
        get(/databases/$(database)/documents/users/$(request.resource.data.toUid)).data.username ==
          request.resource.data.toUsername &&
        request.resource.data.status == 'pending' &&
        request.resource.data.keys().hasAll([
          'fromUid', 'toUid', 'fromUsername', 'toUsername', 'status', 'createdAt', 'updatedAt'
        ]);

      allow update: if isApproved() &&
        resource.data.toUid == request.auth.uid &&
        resource.data.status == 'pending' &&
        request.resource.data.status in ['accepted', 'rejected'];

      allow delete: if isApproved() &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);
    }

    match /blocks/{blockId} {
      allow read: if isSignedIn() &&
        (resource.data.blockerUid == request.auth.uid ||
         resource.data.blockedUid == request.auth.uid);

      allow create: if isApproved() &&
        request.resource.data.blockerUid == request.auth.uid &&
        request.resource.data.blockerUid != request.resource.data.blockedUid &&
        userExists(request.resource.data.blockedUid);

      allow delete: if isApproved() &&
        resource.data.blockerUid == request.auth.uid;

      allow update: if false;
    }

    match /posts/{postId} {
      allow read: if isSignedIn() &&
        canReadAudienceContent(resource.data.audience) &&
        notBlockedWith(resource.data.authorUid);

      allow create: if isApproved() &&
        authorIntegrity(request.resource.data) &&
        textLen(request.resource.data.content, 2000) &&
        request.resource.data.region in ['tr', 'eu'] &&
        request.resource.data.audience in ['all', 'kadin', 'erkek'] &&
        request.resource.data.keys().hasAll([
          'authorUid', 'authorUsername', 'authorGender', 'content',
          'region', 'country', 'city', 'district', 'audience', 'createdAt'
        ]);

      allow update, delete: if isApproved() &&
        resource.data.authorUid == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if isSignedIn() &&
        exists(/databases/$(database)/documents/posts/$(resource.data.postId)) &&
        canReadAudienceContent(
          get(/databases/$(database)/documents/posts/$(resource.data.postId)).data.audience
        ) &&
        notBlockedWith(resource.data.authorUid);

      allow create: if isApproved() &&
        authorIntegrity(request.resource.data) &&
        textLen(request.resource.data.content, 500) &&
        exists(/databases/$(database)/documents/posts/$(request.resource.data.postId)) &&
        canReadAudienceContent(
          get(/databases/$(database)/documents/posts/$(request.resource.data.postId)).data.audience
        ) &&
        notBlockedWith(
          get(/databases/$(database)/documents/posts/$(request.resource.data.postId)).data.authorUid
        ) &&
        request.resource.data.keys().hasAll([
          'postId', 'authorUid', 'authorUsername', 'content', 'createdAt'
        ]);

      allow delete: if isApproved() &&
        resource.data.authorUid == request.auth.uid;

      allow update: if false;
    }

    function isConversationParticipant(conversationId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantUids;
    }

    function lastMessageUpdateAllowed() {
      return request.auth.uid in resource.data.participantUids &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['lastMessageText', 'lastMessageAt', 'lastMessageAuthorUid', 'updatedAt']);
    }

    match /conversations/{conversationId} {
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participantUids;

      allow create: if isApproved() &&
        request.resource.data.keys().hasAll([
          'type', 'participantUids', 'participantUsernames', 'createdBy', 'createdAt', 'updatedAt'
        ]) &&
        request.auth.uid in request.resource.data.participantUids &&
        (
          (request.resource.data.type == 'dm' &&
           request.resource.data.participantUids.size() == 2) ||
          (request.resource.data.type == 'group' &&
           request.resource.data.adminUid == request.auth.uid &&
           textLen(request.resource.data.title, 80) &&
           request.resource.data.keys().hasAll([
             'title', 'region', 'country', 'city', 'district', 'adminUid'
           ]))
        );

      allow update: if isApproved() && lastMessageUpdateAllowed();

      allow delete: if false;

      match /join_requests/{requestUid} {
        allow read, write: if false;
      }

      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId);

        allow create: if isApproved() &&
          isConversationParticipant(conversationId) &&
          authorIntegrity(request.resource.data) &&
          textLen(request.resource.data.content, 2000) &&
          request.resource.data.keys().hasAll([
            'authorUid', 'authorUsername', 'content', 'createdAt'
          ]);

        allow update, delete: if false;
      }
    }

    match /reports/{reportId} {
      allow read, write: if false;
    }

    match /signals/{signalId} {
      allow read: if isSignedIn() &&
        (request.auth.uid in resource.data.notifyUids ||
         resource.data.uid == request.auth.uid);
      allow write: if false;
    }

    match /platform_bans/{banId} {
      allow read, write: if false;
    }

    match /verification_photos/{uid} {
      allow read, write: if false;
    }

    match /fcm_tokens/{tokenId} {
      allow read, write: if false;
    }

    match /reps/{repId} {
      allow read, write: if false;
    }
  }
}
