rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Doğrulanmış (onaylı) kullanıcı mı?
    function isApproved() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.verificationStatus == 'approved';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /friendships/{friendshipId} {
      allow read: if isSignedIn() &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);

      allow create: if isSignedIn() &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.fromUid != request.resource.data.toUid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.keys().hasAll(['fromUid', 'toUid', 'fromUsername', 'toUsername', 'status', 'createdAt', 'updatedAt']);

      allow update: if isSignedIn() &&
        resource.data.toUid == request.auth.uid &&
        resource.data.status == 'pending' &&
        request.resource.data.status in ['accepted', 'rejected'];

      allow delete: if isSignedIn() &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);
    }

    match /blocks/{blockId} {
      allow read: if isSignedIn() &&
        (resource.data.blockerUid == request.auth.uid ||
         resource.data.blockedUid == request.auth.uid);

      allow create: if isSignedIn() &&
        request.resource.data.blockerUid == request.auth.uid &&
        request.resource.data.blockerUid != request.resource.data.blockedUid;

      allow delete: if isSignedIn() &&
        resource.data.blockerUid == request.auth.uid;

      allow update: if false;
    }

    // GÖNDERİLER — okuma herkese, yazma yalnızca onaylı kullanıcıya
    match /posts/{postId} {
      allow read: if isSignedIn();

      allow create: if isApproved() &&
        request.resource.data.authorUid == request.auth.uid &&
        request.resource.data.region in ['tr', 'eu'] &&
        request.resource.data.audience in ['all', 'kadin', 'erkek'] &&
        request.resource.data.authorGender in ['kadin', 'erkek'] &&
        request.resource.data.keys().hasAll([
          'authorUid', 'authorUsername', 'authorGender', 'content',
          'region', 'country', 'city', 'district', 'audience', 'createdAt'
        ]);

      allow update, delete: if isApproved() &&
        resource.data.authorUid == request.auth.uid;
    }

    // YORUMLAR — okuma herkese, yazma yalnızca onaylı kullanıcıya
    match /comments/{commentId} {
      allow read: if isSignedIn();

      allow create: if isApproved() &&
        request.resource.data.authorUid == request.auth.uid &&
        request.resource.data.keys().hasAll([
          'postId', 'authorUid', 'authorUsername', 'content', 'createdAt'
        ]);

      allow delete: if isApproved() &&
        resource.data.authorUid == request.auth.uid;

      allow update: if false;
    }

    function isConversationParticipant(conversationId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantUids;
    }

    // SOHBET — DM + gruplar (canlı dinleyici onSnapshot için read gerekli)
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.participantUids ||
        resource.data.type == 'group'
      );

      allow create: if isApproved() &&
        request.resource.data.keys().hasAll([
          'type', 'participantUids', 'participantUsernames', 'createdBy', 'createdAt', 'updatedAt'
        ]) &&
        request.auth.uid in request.resource.data.participantUids &&
        (
          (request.resource.data.type == 'dm' &&
           request.resource.data.participantUids.size() == 2) ||
          (request.resource.data.type == 'group' &&
           request.resource.data.adminUid == request.auth.uid &&
           request.resource.data.keys().hasAll(['title', 'region', 'country', 'city', 'district', 'adminUid']))
        );

      allow update: if isApproved() && (
        (request.auth.uid in resource.data.participantUids) ||
        (resource.data.type == 'group' &&
         request.auth.uid in request.resource.data.participantUids &&
         !(request.auth.uid in resource.data.participantUids) &&
         request.resource.data.participantUids.size() == resource.data.participantUids.size() + 1)
      );

      allow delete: if false;

      // MESAJLAR — üyeler okur/yazar (canlı chat)
      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId);

        allow create: if isApproved() &&
          isConversationParticipant(conversationId) &&
          request.resource.data.authorUid == request.auth.uid &&
          request.resource.data.keys().hasAll([
            'authorUid', 'authorUsername', 'content', 'createdAt'
          ]);

        allow update, delete: if false;
      }
    }

    match /signals/{signalId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // BAN LİSTESİ — yalnızca sunucu (Admin SDK), client erişemez
    match /platform_bans/{banId} {
      allow read, write: if false;
    }
  }
}
